<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF8F6"
    android:padding="20dp">

    <TextView
        android:id="@+id/lblMainTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INVENTORY CONTROL"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:letterSpacing="0.05"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/lblSubTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Warehouse Scanner Management Console"
        android:textSize="14sp"
        android:textColor="#666666"
        app:layout_constraintTop_toBottomOf="@id/lblMainTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardConfigurations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#DDDDDD"
        app:layout_constraintTop_toBottomOf="@id/lblSubTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT TAG TYPE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:letterSpacing="0.05" />

            <RadioGroup
                android:id="@+id/rgTagType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbTagA4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A4" />

                <RadioButton
                    android:id="@+id/rbTag4pcs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4PCS" />

                <RadioButton
                    android:id="@+id/rbTagVeg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VEG" />

                <RadioButton
                    android:id="@+id/rbTag4pcsDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4PCS_DATE" />

                <RadioButton
                    android:id="@+id/rbTag4pcsSame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4PCS_SAME" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT UNIT TYPE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:letterSpacing="0.05" />

            <RadioGroup
                android:id="@+id/rgUnitType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/rbUnitPcs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PCS" />

                <RadioButton
                    android:id="@+id/rbUnitPkt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PKT" />

                <RadioButton
                    android:id="@+id/rbUnitCtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CTN" />

                <RadioButton
                    android:id="@+id/rbUnitKgs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KGS" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchDuplicateChecking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prevent duplicate scans"
                android:textSize="15sp"
                android:textColor="#111111" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScan"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:text="START SCAN PIPELINE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#00E676"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardConfigurations"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewHistory"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="LOGGED HISTORY &amp; EXPORTS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#111111"
        app:strokeColor="#111111"
        app:strokeWidth="1.5dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
